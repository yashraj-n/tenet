{
  "name": "aura-ai-agent",
  "version": "1.0.0",
  "private": true,
  "description": " Automatically generate, review code from Github Issues & Pull Requests",
  "author": "Yashraj Narke",
  "license": "ISC",
  "homepage": "https://github.com//",
  "keywords": [
    "probot",
    "github",
    "probot-app"
  ],
  "scripts": {
    "watch":"nodemon --exec 'bun dev'",
