    "ioredis": "^5.10.1",
    "nock": "^14.0.5",
    "nodemon": "^3.1.14",
    "smee-client": "^5.0.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@types/pg": "8.15.1"
  },
  "engines": {
    "node": "^20.18.1 || >= 22"
  },
  "type": "module",
  "module": "src/index.ts"
