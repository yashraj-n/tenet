    "dev": "bun src/",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "probot": "^14.3.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.0.0",
